<div class="misc-pf2e-tweaks-tab-customizer-content">

    <h2 class="misc-pf2e-tweaks-tab-customizer-header">Text Tabs</h2>  
    <div class="form-group">
        <label>Enable Text Tabs</label>
        <div class="form-fields">
            <input type="checkbox" name="useTextTabs" {{checked tabConfig.useTextTabs}}>
        </div>
        <p class="hint">When enabled, this will replace the icon-based tabs on the PC sheets with customizable text-based tabs. Using this feature can make the Manage Tabs button on the sheet behave strangely. If you need to customize which tabs are visible, disable this features, make your changes with Manage Tabs, then re-enable this feature.</p> 
    </div>

    <h2 class="misc-pf2e-tweaks-tab-customizer-header">Customize Tab Labels</h2>  
    <p class="misc-pf2e-tweaks-tab-customizer-hint hint">Change the text of the tab labels as you see fit. Leaving a label blank will display the icon in place of text on the tab.</p>
    
    <div class="form-group">
        <label>Character Tab Label</label>
        <div class="form-fields">
            <input type="text" name="character" value="{{tabConfig.tabLabels.character}}">
        </div>
    </div>

    <div class="form-group">
        <label>Actions Tab Label</label>
        <div class="form-fields">
            <input type="text" name="actions" value="{{tabConfig.tabLabels.actions}}">
        </div>
    </div>

    <div class="form-group">
        <label>Inventory Tab Label</label>
        <div class="form-fields">
            <input type="text" name="inventory" value="{{tabConfig.tabLabels.inventory}}">
        </div>
    </div>

    <div class="form-group">
        <label>Spellcasting Tab Label</label>
        <div class="form-fields">
            <input type="text" name="spellcasting" value="{{tabConfig.tabLabels.spellcasting}}">
        </div>
    </div>

    <div class="form-group">
        <label>Crafting Tab Label</label>
        <div class="form-fields">
            <input type="text" name="crafting" value="{{tabConfig.tabLabels.crafting}}">
        </div>
    </div>

    <div class="form-group">
        <label>Proficiencies Tab Label</label>
        <div class="form-fields">
            <input type="text" name="proficiencies" value="{{tabConfig.tabLabels.proficiencies}}">
        </div>
    </div>

    <div class="form-group">
        <label>Feats Tab Label</label>
        <div class="form-fields">
            <input type="text" name="feats" value="{{tabConfig.tabLabels.feats}}">
        </div>
    </div>

    <div class="form-group">
        <label>Effects Tab Label</label>
        <div class="form-fields">
            <input type="text" name="effects" value="{{tabConfig.tabLabels.effects}}">
        </div>
    </div>

    <div class="form-group">
        <label>Biography Tab Label</label>
        <div class="form-fields">
            <input type="text" name="biography" value="{{tabConfig.tabLabels.biography}}">
        </div>
    </div>

    <div class="form-group">
        <label>PFS Tab Label</label>
        <div class="form-fields">
            <input type="text" name="pfs" value="{{tabConfig.tabLabels.pfs}}">
        </div>
    </div>

    <footer class="misc-pf2e-tweaks-label-customizer-footer form-footer">
        <button class="misc-pf2e-tweaks-label-customizer-btn" type="button" data-action="reset">Reset Labels to Default</button>
        <button class="misc-pf2e-tweaks-label-customizer-btn" type="submit">Save and Close</button>
    </footer>
</div>